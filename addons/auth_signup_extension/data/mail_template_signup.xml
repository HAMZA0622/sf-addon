<odoo>
    <data noupdate="1">
        <!-- Email template for DecoScape new user registration -->
        <record id="mail_template_decoscape_user_signup" model="mail.template">
            <field name="auto_delete" eval="False" />
            <field name="name">DecoScape: Thank You for Registering</field>
            <field name="model_id" ref="base.model_res_users" />
            <field name="subject">DecoScape - Thank You for Registering</field>
            <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ object.email_formatted }}</field>
            <field name="description">Sent to users after they register on DecoScape</field>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0"
                    style="padding-top: 16px; background-color: #FFFFFF; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                    <tr>
                        <td align="center">
                            <table border="0" cellpadding="0" cellspacing="0" width="590"
                                style="padding: 16px; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
                                <tr>
                                    <td align="center" style="min-width: 590px;">
                                        <table border="0" cellpadding="0" cellspacing="0"
                                            width="590"
                                            style="min-width: 590px; background-color: white; padding: 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="top" style="font-size: 13px;">
                                                    <div> Dear <t t-out="object.name or ''">Valued
                                                        Customer</t>,<br /><br /> Thank you for
                                                        registering at DecoScape!<br /><br /> Your
                                                        account has now been created, and you can
                                                        log in using your email address and password
                                                        once your registration has been approved.
                                                        Please allow us up to 24 hours for approval.<br /><br />
                                                        To log in, visit our website or click the
                                                        following link: <div style="margin: 16px 0;">
                                                            <a t-attf-href="/web/login"
                                                                style="background-color: #875A7B; padding: 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                                        Go to My Account
                                                            </a>
                                                        </div>
                                                        Upon logging in, you will be able to access
                                                        additional services, including reviewing
                                                        past orders, printing invoices, and updating
                                                        your account information.<br /><br />
                                                        Thanks,<br /> The DecoScape Team </div>
                                                </td>
                                            </tr>

                                        </table>
                                    </td>
                                </tr>

                            </table>
                        </td>
                    </tr>
                </table>
            </field>
            <field name="lang">{{ object.lang }}</field>
            <field name="auto_delete" eval="False" />
        </record>

       <record id="mail_template_decoscape_approval" model="mail.template">
            <field name="name">DecoScape: User Approval Required</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">DecoScape -User Approval Needed</field>
            <field name="email_from">{{ (object.company_id.email_formatted or 'noreply@decoscape.com') }}</field>
            <field name="email_to">{{ object.email_formatted }}</field>
            <field name="description">Template to notify admins about pending user approvals</field>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0"
                    style="padding-top: 16px; background-color: #FFFFFF; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                    <tr>
                        <td align="center">
                            <table border="0" cellpadding="0" cellspacing="0" width="590"
                                style="padding: 16px; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
                                <tr>
                                    <td align="center" style="min-width: 590px;">
                                        <table border="0" cellpadding="0" cellspacing="0"
                                            width="590"
                                            style="min-width: 590px; background-color: white; padding: 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="top" style="font-size: 13px;">
                                                    <div>
                                                        <p>Dear <t t-out="object.name or ''">Admin</t>
                                                            ,</p>
                                                        <p>A new customer has signed up:</p>

                                                        <table
                                                            style="width: 100%; margin: 10px 0; font-size: 13px;">
                                                            <tr>
                                                                <td>
                                                                    <strong>Web Site:</strong>
                                                                </td>
                                                                <td>DecoScape</td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>First Name:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('first_name', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Last Name:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('last_name', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Email:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('new_user_email', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Telephone:</strong>
                                                                </td>
                                                                <td>
                                                                    <t t-out="ctx.get('phone', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Are you currently working with one of our Sales Representatives? If so, who?:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('sales_rep', 'N')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Occupation:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-if="ctx.get('occupation') != 'other'">
                                                                        <t
                                                                            t-out="ctx.get('occupation', '')" />
                                                                    </t>
                                                                    <t
                                                                        t-if="ctx.get('occupation') == 'other'">
                                                                        Other (<t
                                                                            t-out="ctx.get('other_occupation', '')" />
                                                                        )
                                                            </t>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Company:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('company_name', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Address 1:</strong>
                                                                </td>
                                                                <td>
                                                                    <t t-out="ctx.get('street', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Address 2:</strong>
                                                                </td>
                                                                <td>
                                                                    <t t-if="ctx.get('street2')">
                                                                        <t
                                                                            t-out="ctx.get('street2', '')" />
                                                                    </t>
                                                                    <t t-if="not ctx.get('street2')">
                                                                        [Empty]</t>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>City:</strong>
                                                                </td>
                                                                <td>
                                                                    <t t-out="ctx.get('city', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Country:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('country_name', '')" />
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>
                                                                    <strong>Region/State:</strong>
                                                                </td>
                                                                <td>
                                                                    <t
                                                                        t-out="ctx.get('state_name', '')" />
                                                                </td>
                                                            </tr>
                                                        </table>

                                                        <p>Best regards,<br />The DecoScape Team</p>
                                                    </div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="text-align:center;">
                                                    <hr width="100%"
                                                        style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0;" />
                                                    <p style="font-size: 11px; color: #888888;">
                                                        This is an automated message from DecoScape.
                                                        Please do not reply.
                                                    </p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </field>
            <field name="lang">{{ object.lang }}</field>
            <field name="auto_delete" eval="False" />
        </record>

        <record id="mail_template_decoscape_user_activation" model="mail.template">
            <field name="auto_delete" eval="False" />
            <field name="name">DecoScape - Your Account has been activated</field>
            <field name="model_id" ref="base.model_res_users" />
            <field name="subject">DecoScape - Your Account has been activated!</field>
            <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ object.email_formatted }}</field>
            <field name="description">Sent to users after they are actived in system</field>
            <field name="body_html" type="html">
                <p>Welcome and thank you for registering at <strong>DecoScape</strong>!</p>

                <p>Your account has now been created and you can log in by using your email address and password at:</p>

                <p><a href="https://www.decoscape.com/web/login">https://www.decoscape.com/web/login</a></p>

                <p>Upon logging in, you will be able to access other services including reviewing past orders, printing invoices, and editing your account information.</p>

                <p>Thanks,<br/>DecoScape</p>

                </field>
            <field name="lang">{{ object.lang }}</field>
        </record>




    </data>
</odoo>