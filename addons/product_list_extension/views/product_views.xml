<odoo>
    <record id="view_product_template_form_extended" model="ir.ui.view">
        <field name="name">product.template.form.extended.description</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='sales']" position="inside">
                <group>
                    <field name="x_product_name_extended"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>