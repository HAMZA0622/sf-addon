<odoo>
    <template id="user_import_form_template" name="User Import Form">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h2>Import Users via CSV</h2>
                
                <!-- Upload form -->
                <form action="/user/import" method="post" enctype="multipart/form-data" class="oe_import_form">
                    
                    <!-- CSRF Token for security -->
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    
                    <div class="mb-3">
                        <label for="csv_file" class="form-label">Select CSV File:</label>
                        <input type="file" id="csv_file" name="csv_file" class="form-control" required="required" />
                    </div>

                    <button type="submit" class="btn btn-primary">Upload CSV</button>
                </form>

                <!-- Error/Success Message -->
                <t t-if="error">
                    <p class="alert alert-danger mt-3" role="alert">
                        <t t-esc="error"/>
                    </p>
                </t>

                <t t-if="message">
                    <p class="alert alert-success mt-3" role="alert">
                        <t t-esc="message"/>
                    </p>
                </t>
            </div>
        </t>
    </template>
</odoo>
