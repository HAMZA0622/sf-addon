<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="inherited_product_attribute_form_view" model="ir.ui.view">
            <field name="name">inherited.product.attribute.form.view</field>
            <field name="model">product.attribute</field>
            <field name="inherit_id" ref="product.product_attribute_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="image" widget="image" class="oe_avatar text-start float-none" options="{'size': [1024, 1024]}"/>
                    <field name="show_in_finishes"/>
                </xpath>
                <xpath expr="//field[@name='image']" position="attributes">
                    <attribute name="options">{'size': [1024, 1024]}</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
