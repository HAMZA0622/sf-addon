<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- View website.menu form -->
    <record id="theme_view_website_menu_form" model="ir.ui.view">
        <field name="name">view.website.menu.form</field>
        <field name="model">website.menu</field>
        <field name="inherit_id" ref="website.website_menus_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_mega_menu']" position="after">
                <field name="is_dynamic_submenu"/>
                <field name="submenu_model_selection" invisible="is_dynamic_submenu == False"/>
            </xpath>
            <xpath expr="//sheet/group//field[@name='parent_id']" position="replace">

            </xpath>
            <xpath expr="//sheet/group" position="after">
                <field name="ecom_categ_ids" invisible="submenu_model_selection != 'ecom' or is_dynamic_submenu == False">
                    <list editable="bottom" decoration-info="sequence">
                        <field name="sequence" widget="handle" />
                        <field name="category_id"/>
                    </list>
                </field>
                <field name="collection_ids" invisible="submenu_model_selection != 'collection' or is_dynamic_submenu == False">
                    <list editable="bottom" decoration-info="sequence">
                        <field name="sequence" widget="handle" />
                        <field name="collection_id"/>
                    </list>
                </field>
                <!-- <field name="prod_ids" invisible="submenu_model_selection != 'prod' or is_dynamic_submenu == False">
                    <tree editable="bottom" decoration-info="sequence">
                        <field name="sequence" widget="handle" />
                        <field name="product_id" />
                    </tree>
                </field> -->
                <group>
                    <field name="parent_id" context="{'display_website': True}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
