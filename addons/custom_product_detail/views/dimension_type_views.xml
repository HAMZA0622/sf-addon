<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_dimension_type_list_view" model="ir.ui.view">
            <field name="name">product.dimension.type.set.list.view</field>
            <field name="model">dimension.type</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="product_dimension_type_action" model="ir.actions.act_window">
            <field name="name">Product Dimension</field>
            <field name="res_model">dimension.type</field>
            <field name="view_mode">list</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new collection
                </p>
            </field>
        </record>

        <menuitem
                id="menu_product_dimension_type"
                name="Product Dimensions"
                parent="sale.product_menu_catalog"
                action="product_dimension_type_action"
                sequence="25"/>

    </data>
</odoo>
