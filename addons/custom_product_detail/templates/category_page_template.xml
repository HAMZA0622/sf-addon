<odoo>
    <template id="category_page_template" name="Product Category Page">
        <t t-call="website.layout">
            <div class="container">
                <div class="text-center mt-5 mb-5">
                    <h4>PRODUCTS</h4>
                </div>
                <div class="row justify-content-center mt-4">
                    <t t-foreach="ecommerce_categories" t-as="categ" t-key="categ.id">
                        <div class="col-lg-6 col-md-6 col-sm-12 mb-4 d-flex justify-content-center">
                            <div class="finish-card">
                                <a t-att-href="'/shop/category/%s' % slug(categ)">
                                <img t-att-src="'/web/image/%s/%s/image_1920' % ('product.public.category', categ.id)" class="finish-image" />
                                <div class="finish-title">
                                    <t t-esc="categ.name" />
                                </div>
                                </a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
