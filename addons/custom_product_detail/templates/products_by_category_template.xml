<odoo>
    <template id="products_by_category_template" name="Products by Category Page">
        <t t-call="website.layout">
            <div class="category-banner-container mb-5">
                <img t-att-src="'/web/image/%s/%s/image_1920' % ('product.public.category', category.id)"
                     class="banner-image"/>
            </div>

            <div class="container" style="padding-left: 8%; padding-right: 8%; margin-top:100px;">
                <h4 class="text-center mb-5 text-uppercase">
                    <t t-esc="category.name"/>
                </h4>

                <!-- Product Template Grid -->
                <div class="container">
                    <div class="row justify-content-center" style="margin-top:50px;">
                        <t t-foreach="product_templates" t-as="product" t-key="product.id">
                            <div class="col-lg-4 col-md-6 col-sm-12 mb-5 d-flex justify-content-center">
                                <div class="product-card">
                                    <!-- Product Image -->
                                    <img t-att-src="('/web/image/product.template/' + str(product.id) + '/image_1920')"
                                         class="product-image" alt="Product Image"/>

                                    <!-- Product Name -->
                                    <div class="product-title">
                                        <t t-esc="product.name"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
