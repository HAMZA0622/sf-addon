<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_submenu_inherit" inherit_id="website.submenu">
        <xpath expr="//li[@t-if='submenu.is_visible and not (submenu.child_id or submenu.is_mega_menu)']/a" position="after">
            <ul t-if="submenu.is_dynamic_submenu and submenu.submenu_model_selection == 'ecom'" class="dropdown-menu" role="menu">
                <t t-set="ecommerce_category" t-value="request.env['website.menu'].sudo().search([('id', '=', submenu.id)]).ecom_categ_ids"/>
                <t t-foreach="ecommerce_category.category_id" t-as="ecom_category">
                    <li t-if="not ecom_category.parent_id">
                        <a t-attf-href="/shop/category/#{slug(ecom_category)}"
                            t-field="ecom_category.name"/>
                    </li>
                </t>
            </ul>
            
            <ul t-if="submenu.is_dynamic_submenu and submenu.submenu_model_selection == 'collection'" class="dropdown-menu" role="menu">
                <t t-set="product_collection" t-value="request.env['website.menu'].sudo().search([('id', '=', submenu.id)]).collection_ids"/>

                <t t-foreach="product_collection.collection_id.filtered(lambda c: not c.parent_id)" t-as="collection">
                    <li>
                        <a t-attf-href="/collections/#{slug(collection)}">
                            <t t-esc="collection.name"/>
                            <t t-if="collection.child_ids">
                            </t>
                        </a>
                    </li>
                    <ul t-if="collection.child_ids" class="sub-dropdown">
                        <t t-foreach="collection.child_ids.sorted('sequence')" t-as="subcollection">
                            <li>
                                <a t-attf-href="/collections/#{slug(subcollection)}">
                                    <t t-esc="subcollection.name"/>
                                </a>
                            </li>
                        </t>
                    </ul>
                </t>
            </ul>

            <ul t-if="submenu.is_dynamic_submenu and submenu.submenu_model_selection == 'prod'" class="dropdown-menu" role="menu">
                <t t-set="product_ids" t-value="request.env['website.menu'].sudo().search([('id', '=', submenu.id)]).prod_ids"/>
                <t t-foreach="product_ids.product_id" t-as="prod">
                    <li>
                        <a t-if="prod.website_url" t-att-href="prod.website_url"
                            t-field="prod.name"/>
                    </li>
                </t>
            </ul>
        </xpath>
    </template>


</odoo>
