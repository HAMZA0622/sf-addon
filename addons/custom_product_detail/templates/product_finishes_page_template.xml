<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="product_finishes_page_template" name="Finishes">
        <t t-call="website.layout">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center pt-5">
                        <h2>FINISHES</h2>
                    </div>
                </div>
                <div class="row justify-content-center mt-4">
                    <t t-foreach="product_attributes" t-as="attribute" t-key="attribute.id">
                        <div class="col-lg-4 col-md-6 col-sm-12 mb-4 d-flex justify-content-center">
                            <div class="finish-card">
                                 <!-- Link to Attribute Detail Page -->
                                <a t-att-href="'/finishes/%s' % slug(attribute)">
                                <!-- Image Block -->
                                <img t-att-src="'/web/image/%s/%s/image' % ('product.attribute', attribute.id)" class="finish-image" />

                                <!-- Attribute Name Over Image Bottom -->
                                <div class="finish-title">
                                    <t t-esc="attribute.name" />
                                </div>

                                </a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
