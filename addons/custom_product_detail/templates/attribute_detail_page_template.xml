<odoo>
    <template id="attribute_detail_page_template" name="Attribute Detail Page">
        <t t-call="website.layout">
            <t t-set="title"><t t-esc="attribute.name" /></t>
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center pt-5">
                        <h2 class="text-uppercase">
                            <t t-esc="attribute.name" />
                        </h2>
                    </div>
                </div>
                <div class="row justify-content-center mt-4">
                    <t t-foreach="attribute.value_ids" t-as="value" t-key="value.id">
                        <div class="col-lg-3 col-md-4 col-sm-12 mb-4 d-flex justify-content-center">
                            <div class="custom-att-card">
                                <!-- Image Block -->
                                <img t-att-src="'/web/image/%s/%s/image' % ('product.attribute.value', value.id)" class="custom-att-image image-plus" t-att-alt="value.name"/>

                                <!-- Attribute Name Over Image Bottom -->
                                <div class="custom-att-title">
                                    <t t-esc="value.name" />
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
