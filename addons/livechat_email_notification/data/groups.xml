<odoo>
    <record id="group_livechat_end_notification" model="res.groups">
        <field name="name">Live Chat End Notifications</field>
        <field name="comment">Users in this group will receive email notifications when a live chat session ends.</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>
    <record id="decoscape_param_final_message" model="ir.config_parameter">
        <field name="key">decoscape.livechat_final_message</field>
        <field name="value">Thank you for contacting DecoScape, a representative will be in touch soon.</field>
    </record>
</odoo>
